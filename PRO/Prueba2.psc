Proceso Prueba2
	Definir Edad Como Entero;
	Definir Resultado Como Entero ;
	Escribir "Dame tu edad" ;
	Leer Edad ;
	Resultado <- Edad ;
	Escribir "La edad es " , Resultado ;
	Si Resultado >= 18 Entonces
		Escribir "La persona es mayor de edad" ;
	SiNo
		Escribir "La persona es menor de edad" ;
	FinSi
FinProceso